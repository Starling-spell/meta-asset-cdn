{
  "name": "@meta-asset/shelby-client",
  "version": "0.1.0",
  "private": true,
  "description": "The ONLY place the Shelby Protocol SDK is touched. A typed adapter (interface + real impl + mock impl) so the rest of the app never depends on an unverified SDK surface.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@shelby-protocol/sdk": "*"
  },
  "peerDependenciesMeta": {
    "@shelby-protocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@meta-asset/tsconfig": "workspace:*",
    "@types/node": "^22.7.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2"
  }
}
