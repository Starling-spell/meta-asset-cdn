# Copy to .env.local and fill in. Only NEXT_PUBLIC_* vars reach the browser.

# Shelby client mode: "mock" (default, no creds) or "real" (on-chain via @shelby-protocol/sdk).
NEXT_PUBLIC_SHELBY_MODE=mock

# --- Real mode (server-side; the browser never sees these) ---------------------------
# In real mode the browser calls /api/shelby/* and the server signs + pays on-chain with
# a funded Aptos account. Required when NEXT_PUBLIC_SHELBY_MODE=real:

# Aptos private key of the funded service account that signs/pays for uploads.
# SECRET — never prefix with NEXT_PUBLIC_. Fund it with APT + ShelbyUSD on the network first.
# SHELBY_SIGNER_PRIVATE_KEY=0x...

# Shelby/Aptos network: shelbynet (default) | testnet | local
# SHELBY_NETWORK=shelbynet

# Override the Shelby RPC node base URL (optional; SDK has network defaults).
# SHELBY_RPC_URL=https://api.shelbynet.shelby.xyz/shelby

# Override the app's Shelby API route base (optional; defaults to /api/shelby).
# NEXT_PUBLIC_SHELBY_API_BASE=/api/shelby

# Aptos network for registry reads: mainnet | testnet | devnet | local
NEXT_PUBLIC_APTOS_NETWORK=testnet

# Address that published contracts/asset_registry and holds the Registry resource.
# NEXT_PUBLIC_REGISTRY_ADDRESS=0x...

# RPC endpoints for real NFT-ownership checks in the Game Client (see lib/nftGates.ts).
# Public defaults are used if unset.
# NEXT_PUBLIC_EVM_RPC_URL=https://eth.llamarpc.com
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
